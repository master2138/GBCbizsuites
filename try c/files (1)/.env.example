# ─── Database (Neon PostgreSQL) ──────────────────────────────────────────────
# Get these from: https://neon.tech → your project → Connection Details
# Select "Prisma" from the connection string dropdown

# Pooled connection (used by Prisma Client at runtime)
DATABASE_URL="postgresql://username:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"

# Direct connection (used by Prisma Migrate)
DIRECT_URL="postgresql://username:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ─── Clerk (optional — only needed if using Clerk auth) ──────────────────────
CLERK_SECRET_KEY=sk_live_xxxx
